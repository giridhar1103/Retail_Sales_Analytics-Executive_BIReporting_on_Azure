{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-retail-bi-dev-ga"
        },
        "ls_sqlserver_adventureworks_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'ls_sqlserver_adventureworks'"
        },
        "ls_adls_retail_bi_accountKey": {
            "type": "secureString",
            "metadata": "Secure string for 'accountKey' of 'ls_adls_retail_bi'"
        },
        "ls_sqlserver_adventureworks_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "localhost"
        },
        "ls_sqlserver_adventureworks_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "AdventureWorks2022"
        },
        "ls_sqlserver_adventureworks_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "adfuser"
        },
        "ls_adls_retail_bi_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://retailbistoregiri.dfs.core.windows.net/"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "adf-retail-bi-dev-ga_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "ls_adls_retail_bi_accountKey": {
                        "value": "[parameters('ls_adls_retail_bi_accountKey')]"
                    },
                    "ls_sqlserver_adventureworks_password": {
                        "value": "[parameters('ls_sqlserver_adventureworks_password')]"
                    },
                    "ls_adls_retail_bi_properties_typeProperties_url": {
                        "value": "[parameters('ls_adls_retail_bi_properties_typeProperties_url')]"
                    },
                    "ls_sqlserver_adventureworks_properties_typeProperties_server": {
                        "value": "[parameters('ls_sqlserver_adventureworks_properties_typeProperties_server')]"
                    },
                    "ls_sqlserver_adventureworks_properties_typeProperties_database": {
                        "value": "[parameters('ls_sqlserver_adventureworks_properties_typeProperties_database')]"
                    },
                    "ls_sqlserver_adventureworks_properties_typeProperties_userName": {
                        "value": "[parameters('ls_sqlserver_adventureworks_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}